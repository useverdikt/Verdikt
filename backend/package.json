{
  "name": "verdikt-backend",
  "version": "0.1.0",
  "description": "Verdikt MVP backend",
  "main": "src/server.js",
  "scripts": {
    "sync-shared": "node scripts/sync-shared.cjs",
    "postinstall": "node scripts/sync-shared.cjs",
    "start": "node src/server.js",
    "worker": "node src/worker.js",
    "dev": "node src/server.js",
    "test": "node --test-concurrency=1 --test test/*.test.js",
    "test:local-pg": "bash scripts/test-local-pg.sh",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "db:backup": "node scripts/backup-db.js",
    "seed:demos": "node scripts/seed-demo-users.js",
    "seed:demos:supabase": "node scripts/ensure-demo-supabase-auth.js",
    "provision:user": "node scripts/provision-user.js",
    "test:e2e": "bash scripts/test-e2e.sh",
    "test:e2e:live": "start-server-and-test start http://127.0.0.1:8787/health test:e2e",
    "seed:synth": "bash scripts/synth-seed.sh",
    "seed:e2e": "bash scripts/synth-e2e-seed.sh",
    "seed:demo:full": "bash scripts/seed-ws-demo-scenarios.sh"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "start-server-and-test": "^2.0.8",
    "supertest": "^7.1.4"
  }
}
