# Copy to `backend/.env` and fill in. Do not commit `.env`.

# --- AI (optional for some features) ---
AI_PROVIDER=gemini
AI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=   # if AI_PROVIDER=anthropic

ENABLE_THRESHOLD_SUGGESTIONS_LLM=0
ENABLE_ASSISTIVE_LLM=0
AI_CALL_TIMEOUT_MS=3500
AI_CALL_RETRIES=1

# --- Auth & webhooks ---
# Development defaults are unsafe for production. In production (NODE_ENV=production
# or REQUIRE_SECURE_CONFIG=1), JWT_SECRET must be ≥32 chars and WEBHOOK_SECRET ≥24 chars.
JWT_SECRET=
WEBHOOK_SECRET=
# Optional: global HMAC fallback accepted alongside per-workspace inbound webhook secrets (migration / CI).
# WEBHOOK_FALLBACK_SECRET=

# Required in production-like mode: 64 hex chars (32 bytes) for AES-256-GCM encryption of VCS tokens,
# integration API keys, outbound webhook secrets, and per-workspace inbound webhook secrets at rest.
# Generate: openssl rand -hex 32
# ENCRYPTION_MASTER_KEY=

# Self-service POST /api/auth/register: off by default in production-like mode.
# Set to 1 to allow open signups. Use npm run provision:user when closed.
# ALLOW_PUBLIC_REGISTRATION=0
# ALLOW_PUBLIC_REGISTRATION=1

# --- CORS (required when NODE_ENV=production or REQUIRE_SECURE_CONFIG=1) ---
# Comma-separated browser origins, no trailing paths. Must list SPA origins; credentials are enabled for cookie sessions.
# CORS_ORIGINS=https://app.example.com,https://staging.example.com

# --- Cookie session + CSRF (defaults are fine for local dev) ---
# JWT is stored in HttpOnly cookie vdk_auth; CSRF uses readable vdk_csrf + X-CSRF-Token header on mutating requests.
# AUTH_COOKIE_NAME=vdk_auth
# CSRF_COOKIE_NAME=vdk_csrf
# AUTH_COOKIE_MAX_AGE_MS=604800000

# --- Redis (optional): distributed rate limits for multi-instance. When unset, in-memory counters are used.
# REDIS_URL=redis://localhost:6379

# --- Reverse proxy (rate limits, req.ip) ---
# TRUST_PROXY=1

# --- Password reset email (production) ---
# Uses Resend HTTPS API (no extra npm dependency). Create an API key at resend.com.
# PUBLIC_APP_URL must match where the SPA is served (reset link: /reset-password?token=...).
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Verdikt <onboarding@resend.dev>
# PUBLIC_APP_URL=https://app.example.com

# --- Waitlist (/request-access form) ---
# Rows are stored in PostgreSQL (waitlist_requests). Optionally ping your inbox via Resend when both are set:
# WAITLIST_NOTIFY_EMAIL=you@company.com
# WAITLIST_RATE_LIMIT_PER_HOUR=30

# --- DB (required) ---
# PostgreSQL connection string. Migrations run from backend/migrations/postgres on startup.
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/verdikt
# For Supabase: Project Settings → Database (pooler or direct). DATABASE_SSL may auto-enable for *.supabase.co.
# DATABASE_SSL=1
# PG_POOL_MAX=10

# Supabase: JWT Secret (Settings → API) — verifies access_token for POST /api/auth/session-from-supabase.
# SUPABASE_JWT_SECRET=

# Supabase: project URL + service_role — required only for `npm run seed:demos:supabase` (links demo users to Auth).
# Never expose service_role to the browser or commit it.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Tests: npm test uses TEST_DATABASE_URL if set, else DATABASE_URL, else postgresql://127.0.0.1:5432/verdikt_test
# createdb verdikt_test

# --- Ops ---
# PORT=8787
# LOG_JSON=1
# REQUIRE_SECURE_CONFIG=1   # treat like production for config validation without NODE_ENV=production

# Demo accounts on API startup (demo@verdikt.local, screenshots@verdikt.local): enabled when NODE_ENV is not production.
# In production, set to 1 only if you want those seeds on every deploy (usually use `npm run seed:demos` once instead).
# ENABLE_DEMO_SEED=0
# ENABLE_DEMO_SEED=1
