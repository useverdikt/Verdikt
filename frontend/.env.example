# Supabase client (Vercel + Supabase Auth). Backend is Express + PostgreSQL; set these when the SPA uses Supabase sign-in / session.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# API origin for production / preview builds (no trailing slash).
# Example: https://api.yourdomain.com
# Required for `npm run build` when the SPA is served from a different host than the API (set in your host’s env).
# Leave unset in local dev when using `npm run dev` — Vite proxies /api and /health to the backend.
# VITE_API_BASE=https://api.yourdomain.com

# Shown on waitlist errors in production builds (import.meta.env.DEV is false).
# VITE_CONTACT_EMAIL=hello@useverdikt.com

# Join waitlist page /request-access — submits to POST /api/waitlist-requests (proxied in dev). Optional Calendly link:
# VITE_CALENDLY_URL=https://calendly.com/your-org/intro
